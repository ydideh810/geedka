#!/usr/bin/env bash
# Pre-commit guard: blocks methodology/posture disclosure in the public the-stall repo.
# Maintained by Aegis — do not disable without explicit K¹ approval.

set -e

BLOCKED_PATHS=(
  ".backup/"
  "prospector/"
  "PRICING_DOCTRINE.md"
)

BLOCKED_STRINGS=(
  "credentials/keys/aegis-x402-revenue"
  "aegis-x402-revenue"
  "X1 Pro"
  "Minisforum"
  "Signer: Aegis"
  "seam-undercut"
  "autonomy.disclosure"
  "PROSPECTOR"
  "operating autonomously"
  "the-stall-scout"
  "scout.mjs"
  "sequences.mjs"
  "concentration.mjs"
  "bazaar_seed"
  "fund_seeder"
)

STAGED=$(git diff --cached --name-only 2>/dev/null)

# Check blocked paths
for path in "${BLOCKED_PATHS[@]}"; do
  if echo "$STAGED" | grep -q "^${path}"; then
    echo "❌ BLOCKED: Staged files under ${path} are methodology/ops files — move to the-stall-ops."
    exit 1
  fi
done

# Check for scout* pattern
if echo "$STAGED" | grep -qiE "scout"; then
  echo "❌ BLOCKED: Staged file matching *scout* — methodology file. Move to the-stall-ops."
  exit 1
fi

# Check blocked strings in newly-added content only (ignore removed lines so cleanup commits work)
DIFF_CONTENT=$(git diff --cached -- ':!.githooks/' ':!.gitignore' | grep '^+[^+]' || true)
for str in "${BLOCKED_STRINGS[@]}"; do
  if echo "$DIFF_CONTENT" | grep -qF "$str"; then
    echo "❌ BLOCKED: Added content contains '${str}' — methodology/posture disclosure."
    exit 1
  fi
done

echo "✅ OPSEC pre-commit checks passed."
exit 0
