# ── THE STALL · environment ──────────────────────────────────────────────────

# Receiving wallet (payTo). VERIFIED-OWNED.
# EIP-191 signature recovered to this exact address on 2026-05-28.
# See WALLET_VERIFIED.md for the verification audit trail.
WALLET_ADDRESS=0x03d773c52B67993e60Ecb3134b17436fE03B584c

# Network: this payTo is provisioned for Base mainnet only (chainId 8453).
# Override to "base-sepolia" for testnet sandboxing if you ever generate a
# testnet variant, but the production wallet is mainnet.
X402_NETWORK=base

# Facilitator. For mainnet + automatic Bazaar cataloging, use the Coinbase CDP
# facilitator (requires CDP API keys). The x402.org public facilitator default
# below works on testnet only.
FACILITATOR_URL=https://x402.org/facilitator

# Port
PORT=4021

# ── [REDACTED]4 — [REDACTED] ──────────────────────────────────────────

# Archive db path. Default: ./archive.db at repo root. Spine of the long-term
# archive thesis (Schema #3: settlement + identity + mandate joined).
[REDACTED]=archive.db

# Stream 3 — Bazaar discovery diff. NO AUTH REQUIRED. Runs by default.
# BAZAAR_DISCOVERY_URL=https://api.cdp.coinbase.com/platform/v2/x402/discovery/resources
# The Bazaar catalog exceeds 10,000 entries as of 2026-05; even MAX=10000
# truncates. Bump higher if you need full coverage, at the cost of more
# pagination calls per cycle. Default raised from 2000 → 10000 in v0.4.1
# after discovering that anonymous high-strength recipients were ranked
# beyond page 20.
PROSPECTOR_MAX=10000

# Stream 4 — Base mainnet on-chain settlements. NO AUTH REQUIRED (public RPC).
# This is the breakthrough no-auth path for settlement-level data: every
# EIP-3009 transferWithAuthorization on USDC/Base is an x402 settlement, and
# the events are public. Override RPC if you have a private one (QuickNode etc.).
# BASE_RPC_URL=https://mainnet.base.org
# BASE_RPC_CHUNK=500           # blocks per eth_getLogs request
# BASE_RPC_MAX_CHUNKS=10        # chunks per scout run (500*10 = 5000 blocks ≈ 3h history)
# BASE_RPC_BOOTSTRAP=1800       # first-time lookback in blocks (~1h)

# Stream 1 — Cloudflare Radar AI bot timeseries (optional). Free tier with Radar scope.
# CF_API_TOKEN=

# Stream 2 — Dune SQL for x402 (optional secondary source; base_rpc covers the
# same ground without auth). Templates in prospector/dune_queries/.
# DUNE_API_KEY=
# DUNE_QUERY_VOLUME_HOURLY=
# DUNE_QUERY_NEW_ENDPOINTS_24H=

# Stream 5 — x402scan settlement feed (placeholder; no public API as of 2026-05).
# X402SCAN_API_URL=
